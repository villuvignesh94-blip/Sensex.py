                # Sensex Strike gap is 100
                atm = round(spot / 100) * 100
                rows, t_buy, t_sell, t_coi, t_poi = [], 0, 0, 0, 0
                strikes = range(atm-300, atm+400, 100)

                for s in strikes:
                    # Simulated OI/Pressure calculation for Sensex
                    c_oi = abs(int((spot-s)*150+15000)); p_oi = abs(int((s-spot)*150+15000))
                    buy_p = abs(int((s-spot)*450+10000)); sell_p = abs(int((spot-s)*450+10000))
                    t_buy += buy_p; t_sell += sell_p; t_coi += c_oi; t_poi += p_oi
                    
                    pcr_s = round(p_oi / c_oi, 2) if c_oi > 0 else 1.0
                    option_type = "CE" if s <= atm else "PE"
                    str_pwr = (buy_p/(buy_p+sell_p))*100 if buy_p+sell_p > 0 else 50
                    
                    # 🎯 SMC PRECISION LOGIC
                    smc_sig = "⏳ WAIT"
                    if option_type == "CE" and pcr_s > 0.70 and str_pwr > 52: smc_sig = "🚀 CE BUY"
                    elif option_type == "PE" and pcr_s < 0.90 and str_pwr < 48: smc_sig = "🔥 PE BUY"
                    
                    ict_sig = "🚀 ICT BUY" if spot >= h_p else "🔥 ICT SELL" if spot <= l_p else "⏳ WAIT"

                    if "BUY" in smc_sig:
                        if not any(t['Strike'] == s and t['Side'] == smc_sig for t in st.session_state.virtual_trades):
                            st.session_state.virtual_trades.append({'Time': datetime.now().strftime('%H:%M:%S'), 'Strike': s, 'Side': smc_sig, 'Entry': spot})

                    rows.append({
                        "Strike": f"⭐ {s}" if s == atm else str(s), "Type": option_type, 
                        "PCR": f"{pcr_s}", "Target": s+80, "SL": s-40,
                        "SMC": smc_sig, "ICT": ict_sig, 
                        "STR": f"{round(str_pwr,1)}% BUY" if str_pwr > 50 else f"{round(100-str_pwr,1)}% SELL"
                    })

