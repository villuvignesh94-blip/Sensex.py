                            <div style="display:flex; justify-content:space-around; font-size:24px; font-weight:bold; background:#1e1e1e; padding:10px; border-radius:10px; margin-bottom:15px;">
                                <span style="color:#00FBFF;">SENSEX SPOT: {spot}</span>
                                <span style="color:#FFD700;">TOTAL PCR: {total_pcr}</span>
                            </div>
                            <div style="display:flex; justify-content:space-around; font-size:16px; font-weight:bold;">
