# --- 3. DYNAMIC STYLING ---
def style_v120(row):
    styles = [''] * len(row)
    styles[1] = 'color: #00FF00; font-weight: bold' if row['Type'] == 'CE' else 'color: #FF0000; font-weight: bold'
    if "BUY" in str(row['STR']): styles[7] = 'color: #00FF00; font-weight: bold'
    elif "SELL" in str(row['STR']): styles[7] = 'color: #FF0000; font-weight: bold'
    if "BUY" in str(row['SMC']): styles[5] = 'background-color: #228B22; color: #ffffff; font-weight: bold; border: 1px solid white'
    return styles

# --- 4. LIVE DASHBOARD ---
main_view = st.empty()

if st.session_state.get('smart_api'):
    h_p, l_p = 0.0, 999999.0 
    
    while True:
        try:
            # SENSEX TOKEN: 99919000 (BSE)
            res = st.session_state.smart_api.ltpData("BSE", "SENSEX", "99919000")
            if res.get('status'):
                d = res['data']; spot = float(d.get('ltp', 0))
                if h_p == 0: h_p, l_p = float(d.get('high')), float(d.get('low'))
